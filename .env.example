# Google Places API (New) — https://console.cloud.google.com/
# Enable "Places API (New)" and create an API key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Monthly Google API spend cap in USD (default: 50).
# The pipeline will refuse to run if this limit would be exceeded.
# Google's free credit is $200/month — set this lower to stay safe.
GOOGLE_MONTHLY_BUDGET_USD=50

# Anthropic API — https://console.anthropic.com/
# Note: this bills separately from your Claude Code subscription.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
