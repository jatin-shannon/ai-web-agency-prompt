# Google Places API (New) — https://console.cloud.google.com/
# Enable "Places API (New)" and create an API key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Monthly Google API spend cap in USD (default: 50).
# The pipeline will refuse to run if this limit would be exceeded.
# Google's free credit is $200/month — set this lower to stay safe.
GOOGLE_MONTHLY_BUDGET_USD=50

# Anthropic API — https://console.anthropic.com/
# Note: this bills separately from your Claude Code subscription.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App password protection — locks the entire UI behind a password.
# APP_PASSWORD: what you type on the login screen.
# APP_SESSION_TOKEN: any long random string (acts as the session secret).
# Generate one with: openssl rand -hex 32
APP_PASSWORD=choose_a_strong_password_here
APP_SESSION_TOKEN=generate_with_openssl_rand_hex_32

# Vercel Blob — stores generated HTML sites at stable public URLs.
# Set up: Vercel dashboard → Project → Storage → Create Blob Store.
# Vercel adds this token automatically once the store is connected.
# Without it the app falls back to /api/sites/:slug (same-instance only).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
